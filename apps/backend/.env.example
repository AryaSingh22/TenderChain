# TenderChain Backend — Environment Variables
# Copy this file to .env and fill in values

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://tenderchain:tenderchain@localhost:5432/tenderchain

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=4h
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production

# Blockchain
RPC_URL=http://localhost:8545
CHAIN_ID=20240901
RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Contract Addresses (filled after deployment)
TENDER_REGISTRY_ADDRESS=
BID_MANAGER_ADDRESS=
AUDIT_LOG_ADDRESS=
GOVERNANCE_ADDRESS=
DISPUTE_RESOLUTION_ADDRESS=
PERFORMANCE_REGISTRY_ADDRESS=

# IPFS
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080/ipfs

# Notifications (simulated)
TWILIO_ACCOUNT_SID=simulated
TWILIO_AUTH_TOKEN=simulated
TWILIO_PHONE_NUMBER=+1234567890
SENDGRID_API_KEY=simulated
SENDGRID_FROM_EMAIL=noreply@tenderchain.gov

# AI Evaluation (simulated)
ANTHROPIC_API_KEY=simulated

# CORS
FRONTEND_URL=http://localhost:3000
